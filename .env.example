# ============================================================
# Comparative AI Assistant — Environment Configuration
# Copy this file to .env and fill in your values.
# ============================================================

# ------------------------------------
# Frontier Model (Groq API — free tier)
# Get your key at: https://console.groq.com
# ------------------------------------
OPENAI_API_KEY=gsk_your-groq-api-key-here

# Groq uses an OpenAI-compatible endpoint — no code changes needed
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# ------------------------------------
# Model Selection
# ------------------------------------
# OSS backend: "ollama" | "huggingface"
OSS_BACKEND=ollama

# OSS model name
# For Ollama: qwen2.5:1.5b | phi3:mini | llama3.2:1b
# For HuggingFace: Qwen/Qwen2.5-0.5B-Instruct | microsoft/Phi-3-mini-4k-instruct
OSS_MODEL=qwen2.5:1.5b

# Frontier backend: "openai" (Groq is OpenAI-compatible)
FRONTIER_BACKEND=openai

# Frontier model name (Groq-hosted)
# Options: llama-3.1-8b-instant | llama-3.3-70b-versatile | mixtral-8x7b-32768
FRONTIER_MODEL=llama-3.1-8b-instant

# ------------------------------------
# Ollama Configuration
# ------------------------------------
# Ollama server URL (default: http://localhost:11434)
# OLLAMA_HOST=http://localhost:11434

# ------------------------------------
# Memory Configuration
# ------------------------------------
# Number of conversation exchanges to keep in memory
MAX_EXCHANGES=8

# ------------------------------------
# Logging
# ------------------------------------
LOG_LEVEL=INFO
